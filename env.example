# VertiCall — Structure des fichiers

```
verticall/
│
├── CLAUDE.md                          ← Instructions Claude Code (ce fichier)
├── STRUCTURE.md                       ← Ce fichier
├── .env.example                       ← Variables d'environnement
├── .env.local                         ← À créer (ignoré par git)
├── package.json
├── next.config.js
├── tailwind.config.js
├── tsconfig.json
│
├── supabase/
│   └── migrations/
│       └── 001_init.sql               ← Schéma complet base de données
│
├── public/
│   └── logo.svg
│
├── app/
│   ├── globals.css                    ← Variables CSS + polices Google Fonts
│   ├── layout.tsx                     ← Layout racine (providers, fonts)
│   │
│   ├── page.tsx                       ← Page d'accueil publique
│   ├── questionnaire/
│   │   └── page.tsx                   ← Questionnaire public (5 questions)
│   │
│   ├── (auth)/                        ← Pages sans layout connecté
│   │   ├── login/page.tsx
│   │   └── register/page.tsx          ← Choix du rôle client/pro
│   │
│   ├── (client)/                      ← Layout client (sidebar client)
│   │   ├── layout.tsx
│   │   ├── dashboard/page.tsx         ← Liste AO + statuts
│   │   ├── ao/
│   │   │   ├── new/page.tsx           ← Publication AO (3 étapes)
│   │   │   └── [id]/
│   │   │       ├── page.tsx           ← Détail AO
│   │   │       └── offres/page.tsx    ← Comparatif des offres
│   │   └── messages/page.tsx          ← Messagerie client
│   │
│   ├── (pro)/                         ← Layout pro (sidebar pro)
│   │   ├── layout.tsx
│   │   ├── dashboard/page.tsx         ← KPIs + commission du mois
│   │   ├── ao/
│   │   │   ├── page.tsx               ← Liste AO disponibles (filtrés par dép.)
│   │   │   └── [id]/page.tsx          ← Détail AO + formulaire offre
│   │   ├── offres/page.tsx            ← Mes offres soumises
│   │   ├── profil/page.tsx            ← Édition profil pro
│   │   └── messages/page.tsx          ← Messagerie pro
│   │
│   ├── admin/                         ← Dashboard admin
│   │   ├── layout.tsx
│   │   └── page.tsx                   ← KPIs globaux + validation pros
│   │
│   └── api/
│       ├── ao/
│       │   └── route.ts               ← GET (liste) / POST (création)
│       ├── ao/[id]/
│       │   └── route.ts               ← GET / PATCH (statut)
│       ├── offres/
│       │   └── route.ts               ← POST (soumission)
│       ├── offres/[id]/select/
│       │   └── route.ts               ← POST (sélection prestataire)
│       ├── messages/
│       │   └── route.ts               ← GET / POST
│       ├── questionnaire/
│       │   └── route.ts               ← POST (sauvegarde + webhook n8n)
│       └── admin/
│           ├── pros/route.ts          ← GET liste pros à valider
│           └── pros/[id]/verify/
│               └── route.ts           ← POST (valider/refuser)
│
├── components/
│   ├── ui/
│   │   ├── Button.tsx
│   │   ├── Card.tsx
│   │   ├── Badge.tsx
│   │   ├── Input.tsx
│   │   ├── Select.tsx
│   │   ├── Textarea.tsx
│   │   ├── Table.tsx
│   │   ├── Modal.tsx
│   │   ├── Toast.tsx
│   │   └── ScoreBar.tsx               ← Barre de score colorée
│   │
│   ├── forms/
│   │   ├── AOForm.tsx                 ← Formulaire AO multi-étapes
│   │   ├── OffreForm.tsx              ← Soumission d'offre
│   │   ├── ProProfileForm.tsx         ← Profil professionnel
│   │   └── QuestionnaireForm.tsx      ← 5 questions comportementales
│   │
│   ├── layout/
│   │   ├── Navbar.tsx                 ← Navigation principale
│   │   ├── SidebarClient.tsx
│   │   ├── SidebarPro.tsx
│   │   └── Footer.tsx
│   │
│   ├── ao/
│   │   ├── AOCard.tsx                 ← Carte AO dans les listes
│   │   ├── AOStatus.tsx               ← Badge statut AO
│   │   └── OffresTable.tsx            ← Tableau comparatif des offres
│   │
│   └── messages/
│       ├── ChatContainer.tsx
│       ├── MessageBubble.tsx
│       └── ConversationList.tsx
│
└── lib/
    ├── supabase.ts                    ← Client Supabase (browser + server)
    ├── supabase-server.ts             ← Client Supabase server-side
    ├── brevo.ts                       ← Fonctions d'envoi email
    ├── score.ts                       ← Calcul score offres
    ├── middleware.ts                  ← Protection routes par rôle
    └── utils.ts                       ← Helpers divers
```

## Conventions de nommage

- Composants : PascalCase (`AOCard.tsx`)
- Fonctions utilitaires : camelCase (`calculateScore`)
- Variables CSS : kebab-case (`--green-dark`)
- Tables Supabase : snake_case (`appels_offres`)
- Routes API : RESTful (`/api/ao/[id]/offres`)

## Patterns à utiliser

### Récupérer l'utilisateur connecté (server component)
```typescript
import { createServerComponentClient } from '@supabase/auth-helpers-nextjs'
import { cookies } from 'next/headers'

const supabase = createServerComponentClient({ cookies })
const { data: { user } } = await supabase.auth.getUser()
```

### Protéger une route API
```typescript
import { createRouteHandlerClient } from '@supabase/auth-helpers-nextjs'
import { cookies } from 'next/headers'
import { NextResponse } from 'next/server'

export async function POST(req: Request) {
  const supabase = createRouteHandlerClient({ cookies })
  const { data: { user } } = await supabase.auth.getUser()
  if (!user) return NextResponse.json({ error: 'Non autorisé' }, { status: 401 })
  // ...
}
```

### Valider avec Zod
```typescript
import { z } from 'zod'

const schema = z.object({
  titre: z.string().min(5).max(200),
  budget_min: z.number().positive().optional(),
})

const result = schema.safeParse(body)
if (!result.success) {
  return NextResponse.json({ error: result.error.flatten() }, { status: 400 })
}
```
